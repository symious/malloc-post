cmake_minimum_required(VERSION 3.31)
project(malloc-post VERSION 0.1.0 LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

include(FetchContent)

# Download Google Benchmark
set(BENCHMARK_DOWNLOAD_DEPENDENCIES ON CACHE BOOL "" FORCE)
FetchContent_Declare(
    benchmark
    GIT_REPOSITORY https://github.com/google/benchmark.git
    GIT_TAG v1.9.4
)
FetchContent_MakeAvailable(benchmark)

set(MALLOC_IMPLEMENTATIONS jemalloc mimalloc hoard tcmalloc)

# Include directories for homebrew (customize if needed)
set(HOMEBREW_PREFIX /opt/homebrew CACHE PATH "Homebrew prefix")
set(MALLOC_ROOT /ldap_home/yiyang.zhou/malloc CACHE PATH "Custom malloc root")

foreach(MALLOC ${MALLOC_IMPLEMENTATIONS})
  find_library(${MALLOC}_LIBRARY ${MALLOC}
    PATHS
      ${MALLOC_ROOT}/${MALLOC}/lib
      ${MALLOC_ROOT}/${MALLOC}/lib64
      /ldap_home/yiyang.zhou/malloc/gperftools/lib
      /ldap_home/yiyang.zhou/malloc/gperftools/lib64
  )

  if(${MALLOC}_LIBRARY)
    message(STATUS "Found ${MALLOC} at ${${MALLOC}_LIBRARY}")
  else()
    message(WARNING "${MALLOC} not found. Will use system allocator for ${PROJECT_NAME}-${MALLOC}.")
  endif()

  set(EXE_NAME "${PROJECT_NAME}-benchmark-${MALLOC}")
  add_executable(${EXE_NAME} src/main.cpp)
  target_link_libraries(${EXE_NAME} PRIVATE benchmark::benchmark Threads::Threads)

  if(${MALLOC}_LIBRARY)
    target_link_libraries(${EXE_NAME} PRIVATE ${${MALLOC}_LIBRARY})
  endif()

  target_include_directories(${EXE_NAME} PRIVATE include)
endforeach()

# Build with system allocator fallback target name explicitly defined
set(EXE_NAME "${PROJECT_NAME}-benchmark-libmalloc")
add_executable(${EXE_NAME} src/main.cpp)
target_link_libraries(${EXE_NAME} PRIVATE benchmark::benchmark Threads::Threads)
target_include_directories(${EXE_NAME} PRIVATE include)

# Build leak test executables with each malloc implementation
foreach(MALLOC ${MALLOC_IMPLEMENTATIONS})
    set(RSS_EXE_NAME "${PROJECT_NAME}-rss-${MALLOC}")
    add_executable(${RSS_EXE_NAME} src/rss.cpp)

    if(${MALLOC}_LIBRARY)
        target_link_libraries(${RSS_EXE_NAME} PRIVATE ${${MALLOC}_LIBRARY} Threads::Threads)
    endif()
    target_include_directories(${RSS_EXE_NAME} PRIVATE include)
endforeach()

# Build leak test with system allocator
set(RSS_EXE_NAME "${PROJECT_NAME}-rss-libmalloc")
add_executable(${RSS_EXE_NAME} src/rss.cpp)
target_include_directories(${RSS_EXE_NAME} PRIVATE include)
